{
  "pack": "ReasonMath-15",
  "ver": "1.0.0",
  "_note": "示範用題庫;請以 BenchLocal 匯出的實際題目與評分標準取代。",
  "scenarios": {
    "RM-01": {
      "title": "運算順序",
      "category": "arithmetic",
      "prompt": "計算 6 + 12 ÷ 3 × 2 − 4 的值。",
      "criteria": ["遵守先乘除後加減", "最終答案為 10", "過程無計算錯誤"]
    },
    "RM-02": {
      "title": "一元一次方程式",
      "category": "algebra",
      "prompt": "解方程式 3(x − 2) = 2x + 5,求 x。",
      "criteria": ["正確展開與移項", "x = 11", "答案可驗算"]
    },
    "RM-03": {
      "title": "速率問題",
      "category": "word-problem",
      "prompt": "一輛車以 60 km/h 行駛 2.5 小時,接著以 80 km/h 再行駛 1.5 小時,總共行駛多少公里?",
      "criteria": ["分段計算 150 + 120", "總距離 270 公里", "單位正確"]
    },
    "RM-04": {
      "title": "百分比變化",
      "category": "percentage",
      "prompt": "某商品原價 1200 元,先漲價 25%,再打 8 折,最後售價是多少?",
      "criteria": ["先 ×1.25 再 ×0.8", "最後 1200 元", "理解漲後再折的順序"]
    },
    "RM-05": {
      "title": "數列規律",
      "category": "sequence",
      "prompt": "找出規律並寫出下一項:2, 6, 12, 20, 30, ?",
      "criteria": ["辨識相鄰差為 4,6,8,10…", "下一項為 42", "可說明規律(n²+n)"]
    },
    "RM-06": {
      "title": "三段論推理",
      "category": "logic",
      "prompt": "已知:所有 A 都是 B;有些 B 是 C。能否推出『有些 A 是 C』?說明理由。",
      "criteria": ["結論:不能必然推出", "指出 B 與 C 的交集未必含 A", "推理嚴謹"]
    },
    "RM-07": {
      "title": "基礎機率",
      "category": "probability",
      "prompt": "一個袋子有 3 顆紅球、2 顆藍球。連續取兩顆(不放回),兩顆都是紅球的機率?",
      "criteria": ["計算 3/5 × 2/4", "答案為 3/10", "理解不放回"]
    },
    "RM-08": {
      "title": "幾何面積",
      "category": "geometry",
      "prompt": "一個梯形上底 4、下底 10、高 6,求面積。",
      "criteria": ["套用 (上底+下底)×高÷2", "面積 = 42", "單位/公式正確"]
    },
    "RM-09": {
      "title": "多步驟文字題",
      "category": "word-problem",
      "prompt": "小明有些錢,買書花了一半,又花 60 元買筆後剩 90 元。小明原本有多少錢?",
      "criteria": ["逆推:剩 90 + 60 = 150 為一半", "原有 300 元", "列式清楚"]
    },
    "RM-10": {
      "title": "單位換算",
      "category": "conversion",
      "prompt": "把 2.5 小時換算成秒。",
      "criteria": ["2.5 × 3600", "答案 9000 秒", "換算係數正確"]
    },
    "RM-11": {
      "title": "組合計算",
      "category": "combinatorics",
      "prompt": "從 7 個人中選出 3 人組成委員會,有幾種選法?",
      "criteria": ["使用組合 C(7,3)", "答案為 35", "非排列(順序不計)"]
    },
    "RM-12": {
      "title": "比例分配",
      "category": "ratio",
      "prompt": "把 360 元依 2:3:4 分給三人,各得多少?",
      "criteria": ["總份數 9", "分別為 80、120、160", "合計回 360"]
    },
    "RM-13": {
      "title": "邏輯謎題",
      "category": "logic",
      "prompt": "甲乙丙三人,只有一人說謊。甲說:乙說謊。乙說:丙說謊。丙說:甲乙都說謊。誰說謊?",
      "criteria": ["逐一假設檢驗一致性", "結論:乙說謊", "推理過程自洽"]
    },
    "RM-14": {
      "title": "代數化簡",
      "category": "algebra",
      "prompt": "化簡 (x² − 9) / (x − 3),並說明限制。",
      "criteria": ["因式分解 (x+3)(x−3)", "化簡為 x + 3", "註明 x ≠ 3"]
    },
    "RM-15": {
      "title": "估算與合理性",
      "category": "estimation",
      "prompt": "不用精算,估計 49 × 51 約為多少,並說明為何接近 2500。",
      "criteria": ["利用 (50−1)(50+1)=2500−1", "答案 2499", "說明平方差概念"]
    }
  }
}
